{% doc %}
  @prompt
     {{ product.metafields.custom.size.value }}
    
    it has a table html i want to display it as tabl
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-size-table-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    overflow-x: auto;
    margin: {{ block.settings.spacing_top }}px 0 {{ block.settings.spacing_bottom }}px;
  }

  .ai-size-table-{{ ai_gen_id }} table {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-size-table-{{ ai_gen_id }} th {
    background-color: {{ block.settings.header_background }};
    color: {{ block.settings.header_text_color }};
    font-weight: {{ block.settings.header_font_weight }};
    text-align: {{ block.settings.text_alignment }};
    padding: {{ block.settings.cell_padding }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    font-size: {{ block.settings.header_font_size }}px;
  }

  .ai-size-table-{{ ai_gen_id }} td {
    color: {{ block.settings.cell_text_color }};
    text-align: {{ block.settings.text_alignment }};
    padding: {{ block.settings.cell_padding }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    font-size: {{ block.settings.cell_font_size }}px;
  }

  .ai-size-table-{{ ai_gen_id }} tr:nth-child(even) td {
    background-color: {{ block.settings.row_alternate_background }};
  }

  .ai-size-table-{{ ai_gen_id }} tr:hover td {
    background-color: {{ block.settings.row_hover_background }};
  }

  @media screen and (max-width: 749px) {
    .ai-size-table-{{ ai_gen_id }} {
      font-size: {{ block.settings.cell_font_size | times: 0.9 }}px;
    }

    .ai-size-table-{{ ai_gen_id }} th,
    .ai-size-table-{{ ai_gen_id }} td {
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-size-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if product.metafields.custom.size.value != blank %}
    {{ product.metafields.custom.size.value }}
  {% else %}
    <div style="padding: 20px; text-align: center; color: #999; font-style: italic;">
      No size information available for this product
    </div>
  {% endif %}
</div>

