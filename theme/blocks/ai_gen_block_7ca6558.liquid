        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "row_alternate_background",
      "label": "Alternate row background",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "row_hover_background",
