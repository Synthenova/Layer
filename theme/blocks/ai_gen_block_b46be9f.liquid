      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 22
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Table style"
    },
    {
      "type": "color",
      "id": "table_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "table_border_color",
      "label": "Border color",
      "default": "#E6E6E6"
    },
    {
      "type": "range",
      "id": "table_border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "table_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 16,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Header row"
    },
    {
      "type": "color",
      "id": "header_background",
      "label": "Background",
      "default": "#efefef"
    },
    {
      "type": "color",
      "id": "header_text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "header_font_size",
      "label": "Font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "header_font_weight",
      "label": "Font weight",
      "min": 400,
      "max": 700,
