    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Row effects"
    },
    {
      "type": "checkbox",
      "id": "enable_striped_rows",
      "label": "Enable striped rows",
      "default": true
    },
    {
      "type": "color",
      "id": "striped_row_background",
      "label": "Striped row background",
      "default": "#f5f5f5"
