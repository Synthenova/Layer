      "default": 600
    },
    {
      "type": "select",
      "id": "header_text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "header",
      "content": "Table cells"
    },
    {
      "type": "color",
      "id": "cell_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "cell_text_color",
      "label": "Text color",
      "default": "#1c1c1c"
    },
    {
      "type": "range",
      "id": "cell_font_size",
      "label": "Font size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "cell_padding",
      "label": "Cell padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "cell_border_color",
      "label": "Border color",
      "default": "#E6E6E6"
    },
    {
