{% doc %}
  @prompt
    {{ product.metafields.custom.size.specifictions }}
    
    it has a table html i want to display it as table, use this instead "product.metafields.custom.specifications"
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-table-{{ ai_gen_id }} {
    width: 100%;
    display: block;
  }

  .ai-product-table-container-{{ ai_gen_id }} {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ai-product-table-container-{{ ai_gen_id }} table {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background }};
    border: {{ block.settings.table_border_width }}px solid {{ block.settings.table_border_color }};
    border-radius: {{ block.settings.table_border_radius }}px;
    overflow: hidden;
  }

  .ai-product-table-container-{{ ai_gen_id }} th,
  .ai-product-table-container-{{ ai_gen_id }} td {
    padding: {{ block.settings.cell_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    border: {{ block.settings.cell_border_width }}px solid {{ block.settings.cell_border_color }};
  }

  .ai-product-table-container-{{ ai_gen_id }} th {
    background-color: {{ block.settings.header_background }};
    color: {{ block.settings.header_text_color }};
    font-weight: {{ block.settings.header_font_weight }};
    font-size: {{ block.settings.header_font_size }}px;
    text-transform: {{ block.settings.header_text_transform }};
  }

  .ai-product-table-container-{{ ai_gen_id }} td {
    background-color: {{ block.settings.cell_background }};
    color: {{ block.settings.cell_text_color }};
    font-size: {{ block.settings.cell_font_size }}px;
  }

  .ai-product-table-container-{{ ai_gen_id }} tr:nth-child(even) td {
    {% if block.settings.enable_striped_rows %}
      background-color: {{ block.settings.striped_row_background }};
    {% endif %}
  }

  .ai-product-table-container-{{ ai_gen_id }} tr:hover td {
    {% if block.settings.enable_row_hover %}
      background-color: {{ block.settings.row_hover_background }};
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-product-table-container-{{ ai_gen_id }} th,
    .ai-product-table-container-{{ ai_gen_id }} td {
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
      font-size: {{ block.settings.cell_font_size | times: 0.9 }}px;
    }

    .ai-product-table-container-{{ ai_gen_id }} th {
      font-size: {{ block.settings.header_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-product-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_heading and block.settings.heading != blank %}
    <h3 style="margin-bottom: 16px; color: {{ block.settings.heading_color }}; font-size: {{ block.settings.heading_size }}px;">
      {{ block.settings.heading }}
    </h3>
  {% endif %}

  <div class="ai-product-table-container-{{ ai_gen_id }}">
    {% if product.metafields.custom.specifications != blank %}
      {{ product.metafields.custom.specifications }}
    {% else %}
      <div style="padding: 20px; text-align: center; color: #999; font-style: italic;">
        No specifications available for this product
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
