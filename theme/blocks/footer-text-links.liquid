{% liquid
  assign block_settings = block.settings
%}

<div class="footer-block__details-content" {{ block.shopify_attributes }}>
  {%- if block_settings.heading != blank -%}
    <h2 class="footer-block__heading {{ block_settings.heading_preset }}">
      {{- block_settings.heading | escape -}}
    </h2>
  {%- endif -%}

  <ul class="list-unstyled">
    {%- for i in (1..3) -%}
      {%- capture link_text_key -%}link_{{ i }}_text{%- endcapture -%}
      {%- capture link_url_key -%}link_{{ i }}_url{%- endcapture -%}
      {%- assign link_text = block_settings[link_text_key] -%}
      {%- assign link_url = block_settings[link_url_key] -%}

      {%- if link_text != blank -%}
        <li class="footer-block__details-content-item">
          <a
            href="{{ link_url | default: '#' }}"
            class="link link--text list-menu__item list-menu__item--link{% if block_settings.link_preset != blank %} {{ block_settings.link_preset }}{% endif %}"
          >
            {{ link_text }}
          </a>
        </li>
      {%- endif -%}
    {%- endfor -%}
  </ul>
</div>

{% schema %}
{
  "name": "Footer Text Links",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Quick Links"
    },
    {
      "type": "select",
      "id": "heading_preset",
      "label": "Heading Size",
      "options": [
        { "value": "h4", "label": "Small" },
        { "value": "h3", "label": "Medium" },
        { "value": "h2", "label": "Large" }
      ],
      "default": "h4"
    },
    {
      "type": "header",
      "content": "Link 1"
    },
    {
      "type": "text",
      "id": "link_1_text",
      "label": "Text",
      "default": "Link 1"
    },
    {
      "type": "url",
      "id": "link_1_url",
      "label": "URL"
    },
    {
      "type": "header",
      "content": "Link 2"
    },
    {
      "type": "text",
      "id": "link_2_text",
      "label": "Text",
      "default": "Link 2"
    },
    {
      "type": "url",
      "id": "link_2_url",
      "label": "URL"
    },
    {
      "type": "header",
      "content": "Link 3"
    },
    {
      "type": "text",
      "id": "link_3_text",
      "label": "Text",
      "default": "Link 3"
    },
    {
      "type": "url",
      "id": "link_3_url",
      "label": "URL"
    },
    {
      "type": "select",
      "id": "link_preset",
      "label": "Link Style",
      "options": [
        { "value": "body", "label": "Body" },
        { "value": "caption", "label": "Caption" }
      ],
      "default": "body"
    }
  ],
  "presets": [
    {
      "name": "Footer Text Links"
    }
  ]
}
{% endschema %}
