<section class="py-24 bg-white" id="experience-gallery">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-4xl font-bold text-center mb-12 tracking-tight">The Bloom Family</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 auto-rows-[200px] md:auto-rows-[300px]">
      <div class="col-span-2 row-span-2 relative overflow-hidden gallery-item rounded-xl" data-row="1">
        <video
          class="absolute inset-0 w-full h-full object-cover"
          autoplay
          loop
          muted
          playsinline
          preload="none"
          data-bloom-video
          data-bloom-video-priority="3"
          data-bloom-video-src="{{ 'bloom-lifestyle.mp4' | file_url }}"
          data-bloom-video-key="bloom-lifestyle"
        ></video>
      </div>
      <div class="col-span-1 row-span-1 relative overflow-hidden gallery-item rounded-xl" data-row="1">
        <img
          src="{{ 'sofa-collage.png' | file_url }}"
          alt="Sofa experience"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 hover:scale-105"
        >
      </div>
      <div class="col-span-1 row-span-1 relative overflow-hidden gallery-item rounded-xl" data-row="1">
